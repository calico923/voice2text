# Copy to .env and edit as needed.
MODEL_ID=mistralai/Voxtral-Mini-4B-Realtime-2602
HOST=0.0.0.0
PORT=8000
MAX_MODEL_LEN=4096
DTYPE=bfloat16
# RUNTIME_VENV=/tmp/voice2text-vllm-venv311-clean
# LOG_DIR=/tmp/voice2text-vllm-logs
# WSL-safe baseline for Voxtral Realtime without python3.11-dev / nvcc.
# Raise this later only after validating compile toolchains and throughput.
# VLLM_EXTRA_ARGS='--enforce-eager --max-num-seqs 1'
# Workaround for torch/torch-c-dlpack-ext ABI mismatch seen with some builds.
# Keep this as 1 unless you intentionally validate the optional fast DLPack path.
TVM_FFI_DISABLE_TORCH_C_DLPACK=1
# Recommended by the Voxtral model card when using vLLM nightly.
VLLM_DISABLE_COMPILE_CACHE=1
COMPILATION_CONFIG='{"cudagraph_mode":"PIECEWISE"}'
